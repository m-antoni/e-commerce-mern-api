# Use Node 20 LTS Alpine for lightweight dev environment
FROM node:20-alpine

# Set working directory
WORKDIR /app

# Copy package files first to leverage caching
COPY package*.json ./

# Install all dependencies (including devDependencies)
RUN npm install

# Copy source code
COPY . .

# Expose port for local development
EXPOSE 5000

# Use nodemon for automatic reload in dev
# Assumes you have nodemon installed as a devDependency
CMD ["npm", "run", "dev"]